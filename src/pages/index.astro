---
import { languages } from '@/data/i18n'

// Entry-router fallback: when the browser language isn't one we support
// (es / en / ca / gl), default to English as the international fallback.
const fallback = 'en'
---

<!doctype html>
<html lang={fallback}>
  <head>
    <meta charset="utf-8" />
    <title>Ismael Morejón</title>
    <link rel="canonical" href={`/${fallback}/`} />
    <!-- Send visitors to their browser language if supported, else English.
         Client-side because the site is static (no server to read Accept-Language). -->
    <script is:inline define:vars={{ supported: languages, fallback }}>
      (function () {
        var pick = fallback
        try {
          var prefs =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || fallback]
          for (var i = 0; i < prefs.length; i++) {
            var code = String(prefs[i] || '').toLowerCase().split('-')[0]
            if (supported.indexOf(code) !== -1) {
              pick = code
              break
            }
          }
        } catch (e) {
          /* navigator unavailable — fall back */
        }
        window.location.replace('/' + pick + '/')
      })()
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=/${fallback}/`} />
    </noscript>
  </head>
  <body></body>
</html>
