---
import Head from '@/components/Head.astro'
import '@/styles/global.css'

import type { Lang } from '@/data/i18n'
import { t } from '@/data/i18n'

interface Props {
  title: string
  description?: string
  lang?: Lang
}

const { title, description = '', lang = 'es' } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <Head title={title} description={description} />
    <style is:global>
      /* CV-specific styles — Editorial Terminal print aesthetic */
      @media print {
        :root {
          --print-accent: #5b21b6;
          --print-rule: #d4d4d8;
        }

        @page {
          margin: 1cm 1.2cm;
          size: A4;
        }

        html, body {
          font-size: 10.5pt;
          line-height: 1.5;
          background: white !important;
          color: #1a1a1a !important;
          font-family: 'Geist', system-ui, sans-serif;
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }

        a {
          color: inherit !important;
          text-decoration: none;
        }

        /* Don't orphan paragraphs across pages */
        p {
          widows: 3;
          orphans: 3;
        }

        /* Never break right after a heading */
        h1, h2, h3 {
          page-break-after: avoid;
          break-after: avoid;
        }

        /* Tighter list rhythm */
        ul, ol {
          margin: 0;
        }

        ul li + li {
          margin-top: 0.3rem;
        }

        /* Force single-column print layout for ATS reading order */
        .cv-grid {
          display: block !important;
          grid-template-columns: none !important;
          gap: 0 !important;
        }

        .cv-sidebar {
          margin-top: 1.1rem;
        }

        .print-header {
          border-bottom: 1.25px solid var(--print-accent);
          padding-bottom: 0.7rem;
          margin-bottom: 1.1rem;
        }

        /* Force vertical stacking inside the header (overrides flex utilities) */
        .print-header > div:first-child {
          display: block !important;
          margin-bottom: 0.55rem !important;
        }

        .print-section {
          page-break-inside: avoid;
          break-inside: avoid;
          margin-bottom: 1.4rem;
        }

        /* Section titles: hairline rule below replaces the muted gray */
        .print-title {
          font-size: 10.5pt !important;
          font-weight: 700 !important;
          text-transform: uppercase;
          letter-spacing: 0.12em;
          color: #1a1a1a !important;
          margin-bottom: 0.65rem !important;
          padding-bottom: 0.25rem;
          border-bottom: 1px solid var(--print-rule);
          font-family: 'Geist Mono', ui-monospace, monospace !important;
        }

        /* Accent helpers used by cv components in print only */
        .print-accent {
          color: var(--print-accent) !important;
        }

        /* Font utilities */
        .font-mono {
          font-family: 'Geist Mono', ui-monospace, monospace !important;
        }

        .font-sans {
          font-family: 'Geist', system-ui, sans-serif !important;
        }
      }

      @media screen {
        .cv-container {
          max-width: 800px;
          margin: 0 auto;
          padding: 2rem;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-[--color-bg]">
    <div class="cv-container">
      <!-- Print button (hidden on print) -->
      <div class="no-print mb-6 flex justify-between items-center">
        <a
          href={lang === 'es' ? '/' : '/en'}
          class="text-sm text-[--color-text-muted] hover:text-[--color-accent-primary] transition-colors"
        >
          <span class="text-[--color-text-dark]">&lt;</span> {t(lang, 'cv.back')}
        </a>
        <button
          onclick="window.print()"
          class="px-4 py-2 bg-[--color-bg-surface] border border-[--color-border] rounded text-sm text-[--color-text-muted] hover:text-[--color-accent-primary] hover:border-[--color-accent-primary] transition-colors"
        >
          {t(lang, 'cv.print')}
        </button>
      </div>

      <slot />
    </div>
  </body>
</html>
