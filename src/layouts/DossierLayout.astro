---
import Head from '@/components/Head.astro'
import '@/styles/global.css'

import type { Lang } from '@/data/i18n'
import { t } from '@/data/i18n'

interface Props {
  title: string
  description?: string
  lang?: Lang
}

const { title, description = '', lang = 'es' } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <Head title={title} description={description} lang={lang} noindex />
    <style is:global>
      /* ── Dossier — engineering field report, warm light editorial ───────── */
      .dossier-wrap {
        position: relative;
        max-width: 940px;
        margin: 0 auto;
        padding: 4rem 1.75rem 6rem;
        counter-reset: sec;
      }
      /* Atmospheric glow behind the masthead */
      .dossier-wrap::before {
        content: '';
        position: absolute;
        inset: -10% -20% auto -20%;
        height: 460px;
        background: radial-gradient(60% 100% at 30% 0%, rgba(138, 42, 36, 0.05), transparent 70%);
        pointer-events: none;
        z-index: 0;
      }
      .dossier-wrap > * { position: relative; z-index: 1; }

      /* Page-load stagger */
      @media (prefers-reduced-motion: no-preference) {
        .reveal { opacity: 0; transform: translateY(14px); animation: doss-rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards; }
        .reveal:nth-child(2) { animation-delay: 0.06s; }
        .reveal:nth-child(3) { animation-delay: 0.12s; }
        .reveal:nth-child(4) { animation-delay: 0.18s; }
        .reveal:nth-child(5) { animation-delay: 0.24s; }
        .reveal:nth-child(6) { animation-delay: 0.30s; }
        .reveal:nth-child(7) { animation-delay: 0.36s; }
        .reveal:nth-child(8) { animation-delay: 0.42s; }
        @keyframes doss-rise { to { opacity: 1; transform: none; } }
      }

      /* ── Masthead ───────────────────────────────────────────── */
      .doss-head { padding-bottom: 2.25rem; border-bottom: 1px solid #e4dccd; margin-bottom: 1rem; }
      .doss-eyebrow {
        font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.04em;
        color: #8a2a24; margin-bottom: 1.1rem;
      }
      .doss-title {
        font-family: var(--font-mono); font-weight: 600;
        font-size: clamp(2.4rem, 8vw, 4rem); line-height: 0.98; letter-spacing: -0.04em;
        color: #1f1815; margin: 0;
      }
      .doss-rule { width: 56px; height: 3px; background: #8a2a24; margin: 1.4rem 0; border-radius: 2px; }
      .doss-sub { color: #2b2218; font-size: clamp(1.05rem, 2.4vw, 1.3rem); line-height: 1.45; max-width: 34ch; font-weight: 500; }
      .doss-intro { font-family: var(--font-sans); margin-top: 1.5rem; color: #2b2218; font-size: 1rem; line-height: 1.75; max-width: 64ch; }
      .doss-intro p { margin: 0 0 0.55rem; }
      .doss-meta {
        font-family: var(--font-mono); font-size: 0.74rem; color: #a99f90;
        margin-top: 1.6rem; letter-spacing: 0.02em;
      }
      .doss-meta b { color: #6b6258; font-weight: 500; }
      .doss-stack { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1.1rem; }
      .doss-stack li {
        list-style: none; font-family: var(--font-mono); font-size: 0.72rem;
        color: #6b6258; background: #fffdf9;
        border: 1px solid #e4dccd; border-radius: 5px; padding: 0.22rem 0.6rem;
      }

      /* ── Sections (auto-numbered) ───────────────────────────── */
      .doss-sections { counter-reset: sec; }
      .doss-section { margin-top: 3.25rem; break-inside: avoid; page-break-inside: avoid; }
      .doss-section-head { counter-increment: sec; display: flex; align-items: baseline; gap: 0.85rem; margin-bottom: 0.7rem; }
      .doss-section-head::before {
        content: counter(sec, decimal-leading-zero);
        font-family: var(--font-mono); font-size: 0.95rem; font-weight: 600;
        color: #8a2a24;
        border: 1px solid #d8cdb8; border-radius: 6px;
        padding: 0.1rem 0.5rem; line-height: 1.3; flex: none;
      }
      .doss-section-head h2 {
        font-family: var(--font-mono); font-size: clamp(1.15rem, 3vw, 1.5rem); font-weight: 600;
        color: #1f1815; letter-spacing: -0.01em; margin: 0;
      }
      .doss-body { font-family: var(--font-sans); color: #6b6258; line-height: 1.7; max-width: 66ch; margin: 0 0 1.25rem; }

      /* Screenshot framed as an app window */
      .shot { margin: 0; border: 1px solid #e4dccd; border-radius: 12px; overflow: hidden; background: #fffdf9; box-shadow: 0 12px 30px -16px rgba(31, 24, 21, 0.18); }
      .shot-bar { display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 0.85rem; background: #efe6d3; border-bottom: 1px solid #e4dccd; }
      .shot-dots { display: flex; gap: 0.38rem; }
      .shot-dots span { width: 10px; height: 10px; border-radius: 50%; background: #d8cdb8; }
      .shot-label { font-family: var(--font-mono); font-size: 0.72rem; color: #a99f90; margin-left: 0.45rem; }
      .shot img { display: block; width: 100%; height: auto; }

      .doss-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
      @media (max-width: 660px) { .doss-grid { grid-template-columns: 1fr; } }

      .doss-closing {
        font-family: var(--font-mono); margin-top: 4rem; padding-top: 2rem;
        border-top: 1px solid #e4dccd; color: #8a2a24;
        font-size: clamp(1.05rem, 2.6vw, 1.3rem); line-height: 1.5; font-weight: 500; max-width: 50ch;
      }
      .doss-foot { font-family: var(--font-mono); margin-top: 1.5rem; font-size: 0.76rem; color: #a99f90; }

      /* ── Print / PDF (warm light document, on-brand) ── */
      @media print {
        /* No @page margin here: page.pdf()'s margin option owns the per-page
           margins (a CSS @page margin would override and zero them out). */
        @page { size: A4; }
        html, body { background: #ffffff !important; color: #2b2218 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .no-print { display: none !important; }
        .reveal { opacity: 1 !important; transform: none !important; animation: none !important; }
        .dossier-wrap { max-width: none; padding: 0; }
        .dossier-wrap::before { display: none; }
        .doss-section { margin-top: 1.8rem; }
        .shot { box-shadow: none; }
        a { color: inherit !important; text-decoration: none; }
      }
    </style>
  </head>
  <body class="min-h-screen bg-[#ffffff]">
    <!-- Chrome (hidden on print) -->
    <div class="no-print max-w-[940px] mx-auto px-7 pt-6 flex justify-between items-center">
      <a
        href={lang === 'es' ? '/' : '/' + lang}
        class="text-sm text-[#6b6258] hover:text-[#8a2a24] transition-colors font-mono"
      >
        <span class="text-[#a99f90]">&lt;</span> {t(lang, 'cv.back')}
      </a>
      <button
        onclick="window.print()"
        class="px-4 py-2 bg-[#fffdf9] border border-[#e4dccd] rounded text-sm text-[#6b6258] hover:text-[#8a2a24] hover:border-[#8a2a24] transition-colors font-mono"
      >
        {t(lang, 'cv.print')}
      </button>
    </div>

    <main class="dossier-wrap">
      <slot />
    </main>
  </body>
</html>
