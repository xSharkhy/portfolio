---
import { languages, defaultLang } from '@/data/i18n'
---

<!doctype html>
<html lang={defaultLang}>
  <head>
    <meta charset="utf-8" />
    <title>Ismael Morejón</title>
    <link rel="canonical" href={`/${defaultLang}/`} />
    <!-- Entry router: send visitors to their browser language if supported,
         otherwise the default. Client-side because the site is static (no
         server to read Accept-Language). -->
    <script is:inline define:vars={{ supported: languages, fallback: defaultLang }}>
      (function () {
        var pick = fallback
        try {
          var prefs =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || fallback]
          for (var i = 0; i < prefs.length; i++) {
            var code = String(prefs[i] || '').toLowerCase().split('-')[0]
            if (supported.indexOf(code) !== -1) {
              pick = code
              break
            }
          }
        } catch (e) {
          /* navigator unavailable — fall back */
        }
        window.location.replace('/' + pick + '/')
      })()
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=/${defaultLang}/`} />
    </noscript>
  </head>
  <body></body>
</html>
